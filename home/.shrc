#!/bin/sh
#
# ~/.shrc
#
# - A rcfile to share configurations between multiple shells
#   - Supported shells
#     - dash
#     - bash
#     - zsh
# - Not a POSIX-compatible
#

path () {
  echo "$PATH" | tr : '\n'
}

shinit () {
  exec "$SHELL" "$@"
}

alias g=git
alias v=vim
alias m=man

alias ..='cd ../'
alias ...='cd ../../'
alias ....='cd ../../../'
alias .....='cd ../../../../'

alias dk=docker
alias dkcp='docker compose'

alias cg=cargo
alias cgs='cg +stable'
alias cgb='cg +beta'
alias cgn='cg +nightly'

if [ -t 0 ]; then
  # Disable flow control to use CTRL-S and CTRL-Q for key bindings.
  stty -ixon
fi

if [ -r ~/.local.shrc ]; then
  # shellcheck disable=SC1090
  . ~/.local.shrc
fi
