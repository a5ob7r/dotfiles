#!/bin/sh
#
# ~/.shrc
#
# - A rcfile to share configurations between multiple shells
#   - Supported shells
#     - dash
#     - bash
#     - zsh
# - Not a POSIX-compatible
#

xsource_posix () {
  if [ -r "$1" ]; then
    # Can't track source files because they're specified dynamically by users
    # with the argument.
    # shellcheck disable=SC1090
    . "$1"
  fi
}

path () {
  echo "$PATH" | tr : '\n'
}

shinit () {
  exec "$SHELL" "$@"
}

alias g=git
alias v=vim
alias m=man

alias ..='cd ../'
alias ...='cd ../../'
alias ....='cd ../../../'
alias .....='cd ../../../../'

alias cg=cargo
alias cgs='cg +stable'
alias cgb='cg +beta'
alias cgn='cg +nightly'

if [ -t 0 ]; then
  # Disable flow control to use CTRL-S and CTRL-Q for key bindings.
  stty -ixon
fi

xsource_posix ~/.local.shrc
