#!/bin/sh
#
# ~/.shrc
#
# - A rcfile to share configurations between multiple shells
#   - Supported shells
#     - dash
#     - bash
#     - zsh
# - Not a POSIX-compatible
#

path () {
  echo "$PATH" | tr : '\n'
}

lscolors () {
  echo "${LS_COLORS-}" | tr : '\n'
}

lsicons () {
  echo "${LS_ICONS-}" | tr : '\n'
}

shinit () {
  exec "$SHELL" "$@"
}

# Oceanic Next colorscheme for Linux console.
oceanic_next () {
  printf '\033]P%s' \
    0121c21 \
    1e44754 \
    289bd82 \
    3f7bd51 \
    45486c0 \
    5b77eb8 \
    650a5a4 \
    7ffffff \
    852606b \
    9e44754 \
    A89bd82 \
    Bf7bd51 \
    C5486c0 \
    Db77eb8 \
    E50a5a4 \
    Fffffff \
    ;
  clear
}

alias g=git
alias v=vim
alias m=man

alias ..='cd ../'
alias ...='cd ../../'
alias ....='cd ../../../'
alias .....='cd ../../../../'

alias dk=docker
alias dkcp='docker compose'

alias cg=cargo
alias cgs='cg +stable'
alias cgb='cg +beta'
alias cgn='cg +nightly'

alias hl='command haskellorls --color=auto --extra-color --icons --time-style=iso -ABFhov'

if [ -t 0 ]; then
  # Disable flow control to use CTRL-S and CTRL-Q for key bindings.
  stty -ixon
fi

if [ -r ~/.local.shrc ]; then
  # shellcheck disable=SC1090
  . ~/.local.shrc
fi
